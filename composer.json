{
    "name": "crazy-goat/tikv-client",
    "description": "PHP client for TiKV RawKV API using gRPC extension",
    "type": "library",
    "require": {
        "php": ">=8.2",
        "grpc/grpc": "^1.57",
        "google/protobuf": "^3.25"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "config": {
        "audit": {
            "block-insecure": false
        }
    },
    "autoload": {
        "psr-4": {
            "CrazyGoat\\TiKV\\Client\\": "src/Client/",
            "Coprocessor\\": "src/Proto/Coprocessor/",
            "Deadlock\\": "src/Proto/Deadlock/",
            "Disaggregated\\": "src/Proto/Disaggregated/",
            "Disk_usage\\": "src/Proto/Disk_usage/",
            "Encryptionpb\\": "src/Proto/Encryptionpb/",
            "Eraftpb\\": "src/Proto/Eraftpb/",
            "Errorpb\\": "src/Proto/Errorpb/",
            "Kvrpcpb\\": "src/Proto/Kvrpcpb/",
            "Metapb\\": "src/Proto/Metapb/",
            "Mpp\\": "src/Proto/Mpp/",
            "Pdpb\\": "src/Proto/Pdpb/",
            "Raft_serverpb\\": "src/Proto/Raft_serverpb/",
            "Replication_modepb\\": "src/Proto/Replication_modepb/",
            "Resource_manager\\": "src/Proto/Resource_manager/",
            "Tikvpb\\": "src/Proto/Tikvpb/",
            "Tracepb\\": "src/Proto/Tracepb/",
            "GPBMetadata\\": "src/Proto/GPBMetadata/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CrazyGoat\\TiKV\\Tests\\": "tests/"
        }
    }
}
