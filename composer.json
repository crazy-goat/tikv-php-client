{
    "name": "crazy-goat/tikv-client",
    "description": "PHP client for TiKV RawKV API using gRPC extension",
    "type": "library",
    "require": {
        "php": ">=8.2",
        "grpc/grpc": "^1.57",
        "google/protobuf": "^3.25"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "config": {
        "audit": {
            "block-insecure": false
        }
    },
    "autoload": {
        "psr-4": {
            "CrazyGoat\\TiKV\\Client\\": "src/Client/",
            "CrazyGoat\\Proto\\": "src/Proto/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CrazyGoat\\TiKV\\Tests\\": "tests/"
        }
    }
}
